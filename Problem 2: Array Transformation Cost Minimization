def min_operations(arr, k):
    from collections import Counter

    min_ops = float('inf')

    for target in arr:
        ops = 0
        possible = True

        for num in arr:
            if (num - target) % k != 0:
                possible = False
                break
            ops += abs(num - target) // k

        if possible:
            min_ops = min(min_ops, ops)

    return min_ops if min_ops != float('inf') else -1



