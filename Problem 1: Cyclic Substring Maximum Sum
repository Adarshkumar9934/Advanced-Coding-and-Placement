#include <stdio.h>
#include <string.h>

int max(int a, int b) {
    return (a > b) ? a : b;
}

int maxCyclicSum(char *s) {
    int n = strlen(s);
    int freq[26] = {0};

    int left = 0, right = 0;
    int curr_sum = 0, max_sum = 0;

    while (right < 2 * n) {
        int idx = s[right % n] - 'a';

        while (freq[idx] > 0) {
            int left_idx = s[left % n] - 'a';
            freq[left_idx]--;
            curr_sum -= (left_idx + 1);
            left++;
        }

        freq[idx]++;
        curr_sum += (idx + 1);

        // window size limit
        if (right - left + 1 > n) {
            int left_idx = s[left % n] - 'a';
            freq[left_idx]--;
            curr_sum -= (left_idx + 1);
            left++;
        }

        max_sum = max(max_sum, curr_sum);
        right++;
    }

    return max_sum;
}

int main() {
    char s[100005];
    scanf("%s", s);

    printf("%d\n", maxCyclicSum(s));
    return 0;
}
